rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Admin Info
    match /settings/admin {
      allow read, write: if isSignedIn();
    }

    // Debtors
    match /debtors/{debtorId} {
      allow get: if isSignedIn() && isValidId(debtorId);
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isValidId(debtorId);
    }

    // Accounts
    match /accounts/{accountId} {
      allow get: if isSignedIn() && isValidId(accountId);
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isValidId(accountId);
    }

    // Launch Types
    match /launchTypes/{typeId} {
      allow get: if isSignedIn() && isValidId(typeId);
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isValidId(typeId);
    }

    // Transactions
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && isValidId(transactionId);
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isValidId(transactionId);
    }

    // Parcelas
    match /parcelas/{parcelaId} {
      allow get: if isSignedIn() && isValidId(parcelaId);
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isValidId(parcelaId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
